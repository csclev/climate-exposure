df <- df |>
mutate(resl_zone = case_when(
resl_score < 48  ~ "Low",
resl_score > 62  ~ "High",
TRUE             ~ "Middle"
)) |>
mutate(resl_zone = relevel(factor(resl_zone), ref = "Middle"))
