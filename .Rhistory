source("~/Projects/climate-exposure/paper/R/04_lp_did.R", echo = TRUE)
# Test just the t=1 slice for the High Resilience group
test_data <- md_ols %>% filter(month_t == 1, resl_zone == "High") %>% drop_na(deviation, deviation_prior)
# Run the model without Fixed Effects first to see if it works
model_simple <- lm(deviation ~ deviation_prior, data = test_data)
summary(model_simple)
# Now add only the Month-Year FE
model_mid <- feols(deviation ~ deviation_prior | month_year, data = test_data)
test_data %>%
select(stcofips, month_t, deviation, deviation_prior) %>%
mutate(diff = deviation - deviation_prior) %>%
summarize(mean_diff = mean(diff, na.rm=TRUE), sd_diff = sd(diff, na.rm=TRUE))
# Check if deviation_prior is basically a constant at t=1
summary(test_data$deviation_prior)
table(test_data$deviation_prior == 0)
