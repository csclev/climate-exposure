zone = c("Low", "High", "Middle", "Low", "High", "Middle", "Low", "High", "Middle", "Low", "High", "Middle", "Low", "High", "Middle", "Low", "High", "Middle", "Low", "High", "Middle", "Low", "High", "Middle", "Low", "High", "Middle", "Low", "High", "Middle", "Low", "High", "Middle"),
estimate = c(-0.417, -0.241, -0.447, -0.474, -0.139, -0.418, -0.752, -0.170, -0.551, -0.477, -0.069, -0.415, -0.349, -0.107, -0.390, -0.328, -0.093, -0.425, -0.242, -0.092, -0.373, -0.695, -0.126, -0.350, -0.354, 0.008, -0.371, -0.611, -0.036, -0.376, -0.486, -0.077, -0.263),
std_error = c(0.098, 0.128, 0.062, 0.098, 0.136, 0.065, 0.160, 0.196, 0.092, 0.105, 0.126, 0.063, 0.106, 0.126, 0.057, 0.106, 0.119, 0.066, 0.112, 0.125, 0.060, 0.106, 0.121, 0.062, 0.107, 0.113, 0.060, 0.117, 0.118, 0.059, 0.121, 0.128, 0.062)
) %>%
